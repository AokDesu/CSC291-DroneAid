{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill(superpowers:*)",
      "Skill(anthropic-skills:*)",
      "Skill(feature-dev:*)",
      "Skill(commit-commands:*)",
      "Skill(claude-md-management:*)",

      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(npm *)",
      "Bash(npx --yes @mermaid-js/mermaid-cli *)",
      "Bash(firebase *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(py *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(which *)",
      "Bash(where *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(firebase deploy *)"
    ]
  }
}
